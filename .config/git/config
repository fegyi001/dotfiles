[user]
  name = "Gergely Padányi-Gulyás"
  email = "gergely.padanyi-gulyas@idomsoft.hu"

[core]
  compression = 9
  whiteSpace = "error"
  preloadindex = true

[advice]
  addEmptyPathspec = false
  pushNonFastForward = false
  statusHints = false

[init]
  defaultBranch = "main"

[status]
  branch = true
  showStash = true
  showUntrackedFiles = all

[diff]
  context = 3
  renames = copies
  interHunkContext = 10 

[pager]
  diff = "diff-so-fancy | $PAGER"

[diff-so-fancy]
  markEmptyLines = false

[push]
  autoSetupRemote = true
  default = current
  followTags = true

[pull]
  default = current
  rebase = true

[rebase]
  autoStash = true
  missingCommitsCheck = warn

[log]
  abbrevCommit = true
  graphColors = blue,yellow,cyan,magenta,green,red

[color "decorate"]
  HEAD = red
  branch = blue
  tag = yellow
  remoteBranch = magenta

[color "branch"]
  current = magenta
  local = default 
  remote = yellow
  upstream = green
  plain = blue

[branch]
  sort = -committerdate

[tag]
  sort = -taggerdate
