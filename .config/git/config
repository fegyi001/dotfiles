[user]
  name = "Gergely Padányi-Gulyás"
  email = "work@gpadanyig.com"
  signingkey = "0C0EB27977EB40CD"

[gpg]
  program = /opt/homebrew/bin/gpg

[commit]
  gpgsign = true

[tag]
  gpgsign = true

[credential]
	helper = store

[core]
  compression = 9
  whiteSpace = "error"
  preloadindex = true

[advice]
  addEmptyPathspec = false
  pushNonFastForward = false
  statusHints = false

[init]
  defaultBranch = "main"

[status]
  branch = true
  showStash = true
  showUntrackedFiles = all

[diff]
  context = 3
  renames = copies
  interHunkContext = 10 

[pager]
  pager = delta
	editor = vim
	ignorecase = false
  diff = "diff-so-fancy | $PAGER"

[diff-so-fancy]
  markEmptyLines = false

[delta]
  navigate = true # Use n and N to move between diff sections
  side-by-side = true # Start with side-by-side view

[interactive]
  diffFilter = delta --color-only

[push]
  autoSetupRemote = true
  default = current
  followTags = true

[fetch]
	prune = true

[pull]
  default = current
  # If merge conflict, do this: `git rebase --abort && git pull --no-rebase`, resolve the conflict
  rebase = false

[rebase]
  autoStash = true
  missingCommitsCheck = warn

[log]
  abbrevCommit = true
  graphColors = blue,yellow,cyan,magenta,green,red

[color "decorate"]
  HEAD = red
  branch = blue
  tag = yellow
  remoteBranch = magenta

[color "branch"]
  current = magenta
  local = default 
  remote = yellow
  upstream = green
  plain = blue

[branch]
  sort = -committerdate

[tag]
  sort = -taggerdate

[include]
  path = ~/.git-config-local

