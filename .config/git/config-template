# Git config override for company/enterprise GitHub server
# Copy this file and rename to match your setup, e.g.:
#   - config-company
#   - config-work
#   - config-enterprise
#
# Then update .config/git/config with the appropriate includeIf section:
#
# [includeIf "hasconfig:remote.*.url:*github.company.com*/**"]
#   path = ~/.config/git/config-company

[user]
  email = your.work.email@company.com
  signingkey = YOUR_WORK_GPG_KEY_ID
